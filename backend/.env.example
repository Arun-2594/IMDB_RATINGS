# OMDB API Key - Get one at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_key_from_omdbapi.com

# Anthropic Claude API Key - Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_claude_api_key

# Server port
PORT=3001

# Frontend URL for CORS (your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Cache TTL in seconds (default: 300 = 5 minutes)
CACHE_TTL_SECONDS=300

# Maximum reviews to scrape (default: 15)
MAX_REVIEWS_TO_SCRAPE=15

# Log level (default: info)
LOG_LEVEL=info
